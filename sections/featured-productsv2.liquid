{%- comment -%}
  New Product Carousel Section
  Horizontally aligned cards with customizable button colors
{%- endcomment -%}

<div class="custom-carousel-wrapper">
  <div class="page-width">
    <div class="custom-carousel-header" style="text-align:{{ section.settings.ha }};">
      {% if section.settings.h != blank %}
        <h2 class="custom-carousel-heading">{{ section.settings.h }}</h2>
      {% endif %}
    </div>

    <div class="custom-carousel">
      <button class="custom-carousel-btn prev" aria-label="Scroll left">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
          data-slot="icon"
          style="width: 24px; height: 24px;"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"></path>
        </svg>
      </button>

      <div class="custom-carousel-track-wrapper">
        <div class="custom-carousel-track">
          {% for product in collections[section.settings.col].products limit: section.settings.pts %}
            {% if product.variants.first.inventory_quantity > 0 %}
              <div class="custom-carousel-item">
                <a href="{{ product.url }}">
                  <img
                    src="{{ product.featured_image | img_url: '300x' }}"
                    alt="{{ product.title }}"
                    width="300"
                    height="300"
                  >
                  <div class="custom-carousel-stock">{{ product.variants.first.inventory_quantity }} in stock</div>
                  <div class="custom-carousel-sku">{{ product.variants.first.sku | default: product.id }}</div>
                  <div class="custom-carousel-title">{{ product.title }}</div>
                  <div class="custom-carousel-price">{{ product.price | money }}</div>
                  <div
                    class="yotpo bottomLine"
                    data-appkey="qbd9LFlzEc7Blg0tOCJaevh2cjgTvHbusdHCboqs"
                    data-domain="{{shop.permanent_domain | escape }}"
                    data-product-id="{{ product.id }}"
                    data-product-models="{{ product.id }}"
                    data-name="{{ product.title | escape }}"
                    data-url="{{ shop.url }}{{ product.url }}"
                    data-image-url="{{ product.featured_image | product_img_url: 'large' |replace: '?', '%3F' | replace: '&','%26'}}"
                    data-description="{{ product.description | escape }}"
                    data-bread-crumbs="{% for tag in product.tags %}{{ tag | escape }};{% endfor %}"
                  ></div>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <button class="custom-carousel-btn next" aria-label="Scroll right">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
          data-slot="icon"
          style="width: 24px; height: 24px;"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"></path>
        </svg>
      </button>
    </div>
  </div>
</div>
<style>
  .custom-carousel-wrapper {
    max-width: 100%;
    overflow: hidden;
    background-color: #f5f5f5
  }

  .custom-carousel-header {
    text-align: center;
    margin-bottom: 1rem;
  }

  {% comment %} .custom-carousel-container {
    margin: 0 auto;
    width: 100%;
    padding: 40px 0px;
  } {% endcomment %}

  .custom-carousel {
    position: relative;
    display: flex;
    align-items: center;
  }

  .custom-carousel-track-wrapper {
    overflow-x: auto;
    flex-grow: 1;
    scroll-behavior: smooth;
  }

  .custom-carousel-track {
    display: flex;
    gap: 1rem;
  }

  .custom-carousel-item {
    flex: 0 0 auto;
    width: 200px;
    border-radius: 8px;
    text-align: center;
  }

  .custom-carousel-item img {
    object-fit: contain;
    border: 1px solid rgb(191, 191, 191);
    max-width: 184px;
    height: 197px;
    display: block;
    background: white;
  }

  .custom-carousel-stock {
    font-size: 1.4rem;
    color: #127e37;
    margin-bottom: 0.25rem;
    font-weight: 700;
    text-align: left;
  }

  .custom-carousel-sku {
    font-size: 14px;
    color: #999;
    margin-bottom: 0.25rem;
    font-weight: 300;
    text-align: left;
  }

  .custom-carousel-title {
    text-align: left;
    color:rgb(41, 41, 41);
    margin-bottom: 0.25rem;
    color: #000;
    text-decoration: none;
    line-height: 1.625
  }

  .custom-carousel-item a {
    text-decoration: none;
    color: inherit;
  }

  .custom-carousel-price {
    text-align: left;
    color: #444;
    font-weight: bold;
  }

  .custom-carousel-btn {
    background-color: {{ section.settings.bc }};
    color: white;
    border: none;
    border-radius: 4px;
    width: 56px;
    height: 56px;
    font-size: 1.5rem;
    padding: 16px;
    cursor: pointer;
    transition: opacity 0.3s ease;
    display:none; /* Hide by default */
  }
  @media only screen and (min-width: 668px) {
    .custom-carousel-btn {
      display: block;
    }
  }

   .custom-carousel-btn.next{
    position: absolute;
    right: 0;
  }

  .custom-carousel-btn.prev {
    position: absolute;
    left: 0;
  }

  .custom-carousel-btn:disabled {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.custom-carousel').forEach(function (carousel) {
      const trackWrapper = carousel.querySelector('.custom-carousel-track-wrapper');
      const prevBtn = carousel.querySelector('.custom-carousel-btn.prev');
      const nextBtn = carousel.querySelector('.custom-carousel-btn.next');

      function updateButtons() {
        const scrollLeft = trackWrapper.scrollLeft;
        const maxScrollLeft = trackWrapper.scrollWidth - trackWrapper.clientWidth;

        prevBtn.disabled = scrollLeft <= 0;
        nextBtn.disabled = scrollLeft >= maxScrollLeft - 5;
      }

      prevBtn.addEventListener('click', () => {
        trackWrapper.scrollBy({ left: -300, behavior: 'smooth' });
        setTimeout(updateButtons, 300);
      });

      nextBtn.addEventListener('click', () => {
        trackWrapper.scrollBy({ left: 300, behavior: 'smooth' });
        setTimeout(updateButtons, 300);
      });

      trackWrapper.addEventListener('scroll', updateButtons);
      window.addEventListener('resize', updateButtons);
      setTimeout(updateButtons, 100);
    });
  });
</script>

{% schema %}
{
  "name": "New Product Carousel",
  "settings": [
    {
      "type": "text",
      "id": "h",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "select",
      "id": "ha",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "collection",
      "id": "col",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "pts",
      "label": "Number of products",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 10
    },
    {
      "type": "color",
      "id": "bc",
      "label": "Arrow button color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "New Product Carousel"
    }
  ]
}
{% endschema %}
