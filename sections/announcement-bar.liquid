{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- liquid
  if section.blocks.size > 0
    assign announcement_bar = true
  endif
  assign has_phone = false
  if section.settings.phone_number != blank
    assign has_phone = true
  endif
  assign menu_linklist = linklists[section.settings.menu]
  assign has_menu = false
  if section.settings.menu != blank and menu_linklist.links.size > 0
    assign has_menu = true
  endif
  assign has_left_or_right = false
  if has_phone or has_menu
    assign has_left_or_right = true
  endif
-%}

<div
  class="utility-bar color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator and section.blocks.size > 0 %} utility-bar--bottom-border{% endif %}"
>
  <div class="page-width utility-bar__grid{% if announcement_bar and has_left_or_right %} utility-bar__grid--3-col{% elsif has_left_or_right %} utility-bar__grid--2-col{% endif %}">

    {%- if has_phone -%}
      <div class="utility-bar__left small-hide medium-hide">
        <a href="tel:{{ section.settings.phone_number }}" class="utility-bar__phone-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="16" height="16"><path fill-rule="evenodd" d="M1.5 4.5a3 3 0 0 1 3-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 0 1-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 0 0 6.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 0 1 1.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 0 1-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5Z" clip-rule="evenodd"></path></svg>
          <span>{{ section.settings.phone_number }}</span>
        </a>
      </div>
    {%- endif -%}

    {%- if section.blocks.size == 1 -%}
      <div
        class="announcement-bar"
        role="region"
        aria-label="{{ 'sections.header.announcement' | t }}"
        {{ section.blocks.first.shopify_attributes }}
      >
        {%- if section.blocks.first.settings.text != blank or section.blocks.first.settings.text_mobile != blank -%}
          {%- if section.blocks.first.settings.link != blank -%}
            <a
              href="{{ section.blocks.first.settings.link }}"
              class="announcement-bar__link link link--text focus-inset animate-arrow"
            >
          {%- endif -%}
          <span class="mobile-only">
            <span class="mobile-only">
              {{- section.blocks.first.settings.text_mobile | default: section.blocks.first.settings.text -}}
            </span>
          </span>
          <span class="desktop-only-announcement">
            <p class="announcement-bar__message h5 desktop-only">
              <span class="desktop-only">{{ section.blocks.first.settings.text }}</span>
            </p>
          </span>
          {%- if section.blocks.first.settings.link != blank -%}
            </a>
          {%- endif -%}
        {%- endif -%}
      </div>
    {%- elsif section.blocks.size > 1 -%}
      <slideshow-component
        class="announcement-bar"
        role="region"
        aria-roledescription="{{ 'sections.announcements.carousel' | t }}"
        aria-label="{{ 'sections.announcements.announcement_bar' | t }}"
      >
        <div class="announcement-bar-slider slider-buttons">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'sections.announcements.previous_announcement' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
          <div
            class="grid grid--1-col slider slider--everywhere"
            id="Slider-{{ section.id }}"
            aria-live="polite"
            aria-atomic="true"
            data-autoplay="{{ section.settings.auto_rotate }}"
            data-speed="{{ section.settings.change_slides_speed }}"
          >
            {%- for block in section.blocks -%}
              <div
                class="slideshow__slide slider__slide grid__item grid--1-col"
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                {{ block.shopify_attributes }}
                role="group"
                aria-roledescription="{{ 'sections.announcements.announcement' | t }}"
                aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                tabindex="-1"
              >
                <div
                  class="announcement-bar__announcement"
                  role="region"
                  aria-label="{{ 'sections.header.announcement' | t }}"
                >
                  {%- if block.settings.text != blank or block.settings.text_mobile != blank -%}
                    {%- if block.settings.link != blank -%}
                      <a
                        href="{{ block.settings.link }}"
                        class="announcement-bar__link link link--text focus-inset animate-arrow"
                      >
                    {%- endif -%}
                    <p class="announcement-bar__message h5">
                      <span class="desktop-only">{{ block.settings.text }}</span>
                      <span class="mobile-only">{{ block.settings.text_mobile | default: block.settings.text }}</span>
                    </p>
                    {%- if block.settings.link != blank -%}
                      </a>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'sections.announcements.next_announcement' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
      </slideshow-component>
      {%- if request.design_mode -%}
        <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
        <style>
          /* theme editor power preview fix */
          .announcement-bar-slider .slider__slide[aria-hidden='true'] {
            visibility: hidden;
          }
        </style>
      {%- endif -%}
    {%- endif -%}

    {%- if has_menu -%}
      <div class="localization-wrapper">
        <nav class="utility-bar__nav small-hide medium-hide">
          {%- for link in menu_linklist.links -%}
            <a href="{{ link.url }}" class="utility-bar__nav-link">{{ link.title }}</a>
          {%- endfor -%}
        </nav>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  @media screen and (max-width: 749px) {
    .desktop-only-announcement {
      display: none;
    }
    .mobile-only {
      display: flex;
      font-size: 12px;
      font-weight: 500;
    }
  }
  @media screen and (min-width: 750px) {
    .desktop-only-announcement {
      display: flex;
      font-size: 13px;
      font-weight: 500;
    }
    .mobile-only {
      display: none;
    }
  }

  /* left wrapper */
  .utility-bar__left {
    grid-area: social-icons;
    display: flex;
    align-items: center;
  }

  /* phone link */
  .utility-bar__phone-link {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: rgb(var(--color-foreground));
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
  }
  .utility-bar__phone-link svg {
    width: 13px;
    height: 13px;
  }
  .utility-bar__phone-link:hover {
    opacity: 0.8;
  }

  /* nav menu links */
  .utility-bar__nav {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    justify-content: flex-end;
  }
  .utility-bar__nav-link {
    color: rgb(var(--color-foreground));
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    white-space: nowrap;
  }
  .utility-bar__nav-link:hover {
    opacity: 0.8;
  }
</style>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.announcement-bar.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "t:sections.announcement-bar.settings.change_slides_speed.label",
      "default": 5
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-4"
    },
    {
      "type": "checkbox",
      "id": "show_line_separator",
      "default": true,
      "label": "t:sections.header.settings.show_line_separator.label"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:sections.announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "Desktop announcement text"
        },
        {
          "type": "richtext",
          "id": "text_mobile",
          "default": "t:sections.announcement-bar.blocks.announcement.settings.text.default",
          "label": "Mobile announcement text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name",
      "blocks": [
        {
          "type": "announcement"
        }
      ]
    }
  ]
}
{% endschema %}
