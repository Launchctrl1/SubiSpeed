{%- liquid
  assign social_links = false
  assign localization_forms = false

  if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
    assign social_links = true
  endif

  if localization.available_countries.size > 1 and section.settings.enable_country_selector or section.settings.enable_language_selector and localization.available_languages.size > 1
    assign localization_forms = true
  endif
-%}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'component-cart-notification.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<style>
  header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .header__inline-menu header-menu {
    display: flex;
    align-items: center;
    position: relative;
    z-index: 5;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }

  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  summary.list-menu__item img {
    width: 40px;
    height: 40px;
    margin-right: 5px;
    object-fit: contain;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }

  @media screen and (min-width: 1200px) {
      summary.list-menu__item img {
      width: 50px;
      height: 50px;
    }
  }

  /* Header inline menu */
  .header__inline-menu {
    {% comment %} position: fixed !important;
    top: 102px;
    left: 0;
    width: 100vw !important; {% endcomment %}
    width: 100vw;
    box-sizing: border-box;
    overflow-x: auto !important;
    overflow-y: hidden !important;
    padding: 0px;
    gap: 10px;
    background: #fff;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    z-index: 3;
  }

  .header__inline-menu > ul {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    margin: 0 auto;
    padding-left: var(--first-menu-item-offset, 0);
    width: 100%;
    max-width: 1200px;
    gap: 5px;
  }

  @media screen and (max-width: 749px) {
    .header__inline-menu > ul {
      max-width: 100%;
    }
  }
  @media screen and (min-width: 750px) and (max-width: 989px) {
    .header__inline-menu > ul {
      max-width: 700px;
    }
  }
  @media screen and (min-width: 990px) {
    .header__inline-menu > ul {
      max-width: 1200px;
    }
  }
  @media screen and (min-width: 1200px) {
    .header__inline-menu > ul {
      justify-content: center;
      max-width: 1200px;
    }
  }

  /* Submenu (segundo nivel) */
  .header__submenu {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: nowrap !important;
    white-space: nowrap;
    position: fixed !important;
    {% comment %} top: calc(var(--header-height) + 43px); {% endcomment %}
    left: 0;
    width: 100vw !important;
    box-sizing: border-box;
    overflow-x: auto !important;
    overflow-y: hidden !important;
    padding: 10px;
    gap: 10px;
    background: #f8f8f8;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
    z-index: 998;
  }

  .header__submenu__content {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    padding-left: var(--first-menu-item-offset, 0);
    width: 100%;
    max-width: 1200px;
  }

  /* Items de segundo nivel */
  .header__submenu > .header__submenu__content > li {
    flex: 0 0 auto;
    margin-right: 5px;
    min-width: 60px;
    max-width: 120px;
    height: 30px;
  }

  .header__submenu .header__menu-item {
    padding: 5px 10px;
    border: 1px solid #000;
    border-radius: 6px;
    background: transparent;
    font-size: 12px;
    white-space: nowrap;
    cursor: pointer;
  }

  .header__submenu .childlink-trigger.active {
    background-color: rgb(17, 94, 176);
    color: #fff;
  }

  /* Tercer nivel - subsección fija */
  .header__third-submenu {
    position: fixed;
    top: 195px; /* debajo del segundo nivel */
    left: 0;
    width: 100vw;
    background: #ffffff;
    display: none;
    padding: 10px;
    z-index: 1;
  }
  @media screen and (min-width: 1200px) {
    .header__third-submenu {
      top: 210px;
    }
  }

  .header__third-submenu .third-submenu-wrapper {
    display: flex;
    margin: 0 auto;
    max-width: 1200px;
  }

  .header__third-submenu .third-submenu-sidebar {
    flex: 0 0 15%;
    padding: 20px 20px 20px 0;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .header__third-submenu .third-submenu-sidebar img {
    width: 100%;
    height: auto;
    max-height: 200px;
    object-fit: contain;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .header__third-submenu .third-submenu-main {
    flex: 1;
    padding-left: 10px;
    min-width: 0;
  }

  .header__third-submenu ul {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .header__third-submenu .third-submenu-content {
    display: none;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    list-style: none !important;
    padding: 20px 0;
  }

  .header__third-submenu .third-submenu-content.active {
    display: grid;
  }

  .header__third-submenu .third-submenu-content li {
    display: flex;
    flex-direction: row;
    align-items: center;
    list-style: none !important;
  }

  .header__third-submenu .third-submenu-content li img {
    width: 54px;
    height: 54px;
    object-fit: cover;
    margin-right: 10px;
    border-radius: 4px;
  }

  .header__third-submenu .third-submenu-content li a {
    text-decoration: none;
    color: #333;
    font-size: 14px;
    line-height: 1.4;
  }

  .header__third-submenu .third-submenu-content li a:hover {
    text-decoration: underline;
  }

  .header__third-submenu .third-submenu-content li a:hover {
    color: #000;
  }

  .third-submenu-sidebar-link {
    display: none;
    margin-top: 12px;
    font-size: 13px;
    line-height: 1.4;
    color: #333;
    text-decoration: underline;
    text-align: center;
  }

  .third-submenu-sidebar-link:hover {
    color: #000;
  }

  /* Categories panel (2nd level for section third_level_menu) */
  .header__categories-panel {
    position: fixed;
    top: 154px;
    left: 0;
    width: 100vw;
    background: #ffffff;
    display: none;
    padding: 10px;
    z-index: 997;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  }

  .categories-panel-wrapper {
    margin: 0 auto;
    max-width: 1200px;
  }

  .categories-panel-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 20px;
    list-style: none;
    padding: 20px 0;
    margin: 0;
  }

  .categories-panel-content li {
    display: flex;
    flex-direction: row;
    align-items: center;
    list-style: none;
  }

  .categories-panel-content li img {
    width: 54px;
    height: 54px;
    object-fit: cover;
    margin-right: 10px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .categories-panel-content li a {
    text-decoration: none;
    color: #333;
    font-size: 14px;
    line-height: 1.4;
  }

  .categories-panel-content li a:hover {
    color: #000;
    text-decoration: underline;
  }
</style>

{%- style -%}
  .header {
    padding: {{ section.settings.padding_top | times: 0.5 | round: 0 }}px 3rem {{ section.settings.padding_bottom | times: 0.5 | round: 0 }}px 3rem;
  }
  .section-fitments-header {
    position: sticky;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-fitments-header {
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
  @media screen and (min-width: 990px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

{%- liquid
  for block in section.blocks
    if block.type == '@app'
      assign has_app_block = true
    endif
  endfor
-%}

{% liquid
  assign header_tag = 'div'

  if section.settings.sticky_header_type != 'none'
    assign header_tag = 'sticky-header'
  endif
%}

<{{ header_tag }}
  {% if header_tag == 'sticky-header' %}
    data-sticky-type="{{ section.settings.sticky_header_type }}"
  {% endif %}
  class="header-wrapper color-{{ section.settings.color_scheme }} gradient{% if section.settings.show_line_separator %} header-wrapper--border-bottom{% endif %}"
>
  <div class="header header--{{ section.settings.logo_position }} header--mobile-{{ section.settings.mobile_logo_position }} page-width{% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}{% if section.settings.show_search_bar %} header--has-search-bar{% endif %}">
    {%- liquid
      render 'header-drawer'
    -%}

    {%- if section.settings.logo_position != 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <div class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo motion-reduce',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
      </div>
      {%- endif -%}
    {%- endif -%}

    {%- if section.settings.show_search_bar -%}
      <div class="header__search-bar">
        {%- render 'header-search-modal-content', show_close_button: false -%}
      </div>
    {%- endif -%}

    {%- if section.settings.logo_position == 'middle-center' -%}
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(min-width: 750px) {{ settings.logo_width }}px, 50vw{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    {%- endif -%}

    <div class="header__icons{% if section.settings.enable_country_selector or section.settings.enable_language_selector %} header__icons--localization header-localization{% endif %}">
      <div class="desktop-localization-wrapper">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'HeaderCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {% endif %}
        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form class="small-hide medium-hide" data-prevent-hide>
            {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="visually-hidden" id="HeaderLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'HeaderLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      {%- unless section.settings.show_search_bar -%}
        {% render 'header-search', input_id: 'Search-In-Modal' %}
      {%- endunless -%}

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}"
          rel="nofollow"
        >
          {%- if section.settings.enable_customer_avatar -%}
            <account-icon>
              {%- if customer and customer.has_avatar? -%}
                {{ customer | avatar }}
              {%- else -%}
                <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
              {%- endif -%}
            </account-icon>
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
          {%- endif -%}
          <span class="visually-hidden">
            {%- liquid
              if customer
                echo 'customer.account_fallback' | t
              else
                echo 'customer.log_in' | t
              endif
            -%}
          </span>
        </a>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
        {% if cart == empty %}
          <span class="">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% endif %}
        <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
        {%- if cart != empty -%}
          <div class="cart-count-bubble">
            {%- if cart.item_count < 100 -%}
              <span aria-hidden="true">{{ cart.item_count }}</span>
            {%- endif -%}
            <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
          </div>
        {%- endif -%}
      </a>
    </div>
  </div>
</{{ header_tag }}>

 <nav class="header__inline-menu">
    <ul class="list-menu list-menu--inline" role="list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            {%- assign link = block.settings.menu -%}
            <header-menu>
              <details id="Details-HeaderMenu-{{ forloop.index }}">
                <summary
                  id="HeaderMenu-{{ link.handle }}"
                  class="header__menu-item list-menu__item link focus-inset"
                >
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 100 }}"
                      alt="{{ block.settings.heading }}"
                      width="50"
                      height="50"
                    >
                  {%- endif -%}
                  <span
                    {%- if link.child_active %}
                      class="header__active-menu-item"
                    {% endif %}
                  >
                    {{- link.title | escape -}}
                  </span>
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </summary>
                <ul
                  id="HeaderMenu-MenuList-{{ forloop.index }}"
                  class="header__submenu list-menu list-menu--disclosure color-{{ section.settings.menu_color_scheme }} gradient caption-large motion-reduce global-settings-popup"
                  role="list"
                  tabindex="-1"
                >
                  <div
                    class="header__submenu__content"
                    {% if forloop.index >= 3 %}
                      style="margin: 0 auto;"
                    {% endif %}
                  >
                    {%- for childlink in link.links -%}
                      <li>
                        <button
                          id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                          class="header__menu-item list-menu__item link link--text focus-inset caption-large childlink-trigger{% if childlink.current %} list-menu__item--active{% endif %}"
                          data-handle="{{ childlink.handle }}"
                          type="button"
                          {% if childlink.current %}aria-current="page"{% endif %}
                        >
                          {{ childlink.title | escape }}
                        </button>
                      </li>
                    {%- endfor -%}
                  </div>
                </ul>
              </details>
            </header-menu>

            {%- comment -%} Третий уровень: меню из настройки блока, URL с фильтром из второго уровня {%- endcomment -%}
            <div class="header__third-submenu" data-block-index="{{ forloop.index }}">
              <div class="third-submenu-wrapper page-width">
                <div class="third-submenu-sidebar">
                  {%- if block.settings.sidebar_image -%}
                    <img
                      src="{{ block.settings.sidebar_image | image_url: width: 300 }}"
                      alt="{{ block.settings.heading | escape }} sidebar"
                      loading="lazy"
                      width="300"
                    >
                  {%- endif -%}
                  {%- for childlink in link.links -%}
                    {%- if childlink.links != blank or section.settings.third_level_menu != blank -%}
                      <a
                        href="{%- if section.settings.use_apps_prefix -%}/apps{%- endif -%}{{ childlink.url }}"
                        class="third-submenu-sidebar-link"
                        data-parent="{{ childlink.handle }}"
                      >
                        Shop {{ childlink.title | escape }} {{ link.title | escape }} Products
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <div class="third-submenu-main">
                  {%- assign third_menu = section.settings.third_level_menu -%}
                  {%- if third_menu != blank -%}
                    {%- for childlink in link.links -%}
                      {%- assign url_parts = childlink.url | split: '?' -%}
                      {%- assign filter_string = '' -%}
                      {%- if url_parts.size > 1 -%}
                        {%- assign filter_string = url_parts[1] -%}
                      {%- endif -%}
                      <ul class="third-submenu-content" data-parent="{{ childlink.handle }}">
                        {%- for menulink in third_menu.links -%}
                          {%- assign image_key = 'third_image_' | append: forloop.index -%}
                          {%- if filter_string != blank -%}
                            {%- if menulink.url contains '?' -%}
                              {%- assign final_url = menulink.url | append: '&' | append: filter_string -%}
                            {%- else -%}
                              {%- assign final_url = menulink.url | append: '?' | append: filter_string -%}
                            {%- endif -%}
                          {%- else -%}
                            {%- assign final_url = menulink.url -%}
                          {%- endif -%}
                          <li>
                            {%- if section.settings[image_key] != blank -%}
                              <img
                                src="{{ section.settings[image_key] | image_url: width: 54, height: 54, crop: 'center' }}"
                                alt="{{ menulink.title | escape }}"
                                loading="lazy"
                                width="54"
                                height="54"
                              >
                            {%- endif -%}
                            <a
                              href="{%- if section.settings.use_apps_prefix -%}/apps{%- endif -%}{{ final_url }}"
                              class="header__menu-item list-menu__item link focus-inset caption-large"
                            >
                              {{ menulink.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- if section.settings.third_level_menu != blank -%}
        <header-menu>
          <details id="Details-HeaderMenu-categories">
            <summary
              class="header__menu-item list-menu__item link focus-inset categories-level1-trigger"
            >
              {%- if section.settings.categories_image != blank -%}
                <img
                  src="{{ section.settings.categories_image | image_url: width: 100 }}"
                  alt="{{ section.settings.third_level_menu.title | escape }}"
                  width="50"
                  height="50"
                >
              {%- endif -%}
              <span>{{ section.settings.third_level_menu.title | escape }}</span>
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </summary>
          </details>
        </header-menu>
      {%- endif -%}
    </ul>

    {%- if section.settings.third_level_menu != blank -%}
      <div class="header__categories-panel">
        <div class="categories-panel-wrapper page-width">
          <ul class="categories-panel-content">
            {%- for menulink in section.settings.third_level_menu.links -%}
              {%- assign image_key = 'third_image_' | append: forloop.index -%}
              <li>
                {%- if section.settings[image_key] != blank -%}
                  <img
                    src="{{ section.settings[image_key] | image_url: width: 100 }}"
                    alt="{{ menulink.title | escape }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {%- endif -%}
                <a
                  href="{%- if section.settings.use_apps_prefix -%}/apps{%- endif -%}{{ menulink.url }}"
                  class="header__menu-item list-menu__item link focus-inset caption-large"
                >
                  {{ menulink.title | escape }}
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </nav>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: section.settings.color_scheme,
    desktop_menu_type: section.settings.menu_type_desktop
  -%}
{%- endif -%}

{% javascript %}
  class StickyHeader extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.header = document.querySelector('.section-header');
      this.headerIsAlwaysSticky =
        this.getAttribute('data-sticky-type') === 'always' ||
        this.getAttribute('data-sticky-type') === 'reduce-logo-size';
      this.headerBounds = {};

      this.setHeaderHeight();

      window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));

      if (this.headerIsAlwaysSticky) {
        this.header.classList.add('shopify-section-header-sticky');
      }

      this.currentScrollTop = 0;
      this.preventReveal = false;
      this.predictiveSearch = this.querySelector('predictive-search');

      this.onScrollHandler = this.onScroll.bind(this);
      this.hideHeaderOnScrollUp = () => (this.preventReveal = true);

      this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.addEventListener('scroll', this.onScrollHandler, false);

      this.createObserver();
    }

    setHeaderHeight() {
      document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
    }

    disconnectedCallback() {
      this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
      window.removeEventListener('scroll', this.onScrollHandler);
    }

    createObserver() {
      let observer = new IntersectionObserver((entries, observer) => {
        this.headerBounds = entries[0].intersectionRect;
        observer.disconnect();
      });

      observer.observe(this.header);
    }

    onScroll() {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (this.predictiveSearch && this.predictiveSearch.isOpen) return;

      if (scrollTop > this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (this.preventHide) return;
        requestAnimationFrame(this.hide.bind(this));
      } else if (scrollTop < this.currentScrollTop && scrollTop > this.headerBounds.bottom) {
        this.header.classList.add('scrolled-past-header');
        if (!this.preventReveal) {
          requestAnimationFrame(this.reveal.bind(this));
        } else {
          window.clearTimeout(this.isScrolling);

          this.isScrolling = setTimeout(() => {
            this.preventReveal = false;
          }, 66);

          requestAnimationFrame(this.hide.bind(this));
        }
      } else if (scrollTop <= this.headerBounds.top) {
        this.header.classList.remove('scrolled-past-header');
        requestAnimationFrame(this.reset.bind(this));
      }

      this.currentScrollTop = scrollTop;
    }

    hide() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
      this.closeMenuDisclosure();
      this.closeSearchModal();
    }

    reveal() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.add('shopify-section-header-sticky', 'animate');
      this.header.classList.remove('shopify-section-header-hidden');
    }

    reset() {
      if (this.headerIsAlwaysSticky) return;
      this.header.classList.remove('shopify-section-header-hidden', 'shopify-section-header-sticky', 'animate');
    }

    closeMenuDisclosure() {
      this.disclosures = this.disclosures || this.header.querySelectorAll('header-menu');
      this.disclosures.forEach((disclosure) => disclosure.close());
    }

    closeSearchModal() {
      this.searchModal = this.searchModal || this.header.querySelector('details-modal');
      this.searchModal.close(false);
    }
  }

  customElements.define('sticky-header', StickyHeader);

  document.addEventListener('DOMContentLoaded', () => {
    // Seleccionamos todos los triggers (segundo nivel) con data-handle
    const triggers = document.querySelectorAll('.childlink-trigger');
    // Para cada bloque de header (por si tienes varios bloques/menus) hay un contenedor .header__third-submenu
    const thirdSubmenus = document.querySelectorAll('.header__third-submenu');

    // Función util para ocultar todos los third-submenu y desactivar todos los grupos y highlights
    function hideAllThird() {
      thirdSubmenus.forEach((container) => {
        container.style.display = 'none';
        const groups = container.querySelectorAll('.third-submenu-content');
        groups.forEach((g) => g.classList.remove('active'));
        const sidebarLinks = container.querySelectorAll('.third-submenu-sidebar-link');
        sidebarLinks.forEach((l) => (l.style.display = 'none'));
      });
      // Hide categories panel
      const categoriesPanel = document.querySelector('.header__categories-panel');
      if (categoriesPanel) categoriesPanel.style.display = 'none';
      // Remove active class from all triggers
      triggers.forEach((t) => t.classList.remove('active'));
      document.querySelectorAll('.categories-level1-trigger').forEach((t) => t.classList.remove('active'));
    }

    // Shared: find third-submenu container for a given trigger button
    function getThirdContainer(trigger) {
      // button → li → div.header__submenu__content → ul.header__submenu → details#Details-HeaderMenu-N
      const submenuList = trigger.closest('ul.header__submenu');
      if (!submenuList) return document.querySelector('.header__third-submenu');

      const details = submenuList.parentElement;
      if (details && details.id) {
        const match = details.id.match(/Details-HeaderMenu-(\d+)/);
        if (match) {
          return document.querySelector(`.header__third-submenu[data-block-index="${match[1]}"]`);
        }
      }

      return document.querySelector('.header__third-submenu');
    }

    // Shared: show third level for a given trigger
    function showThirdLevel(trigger) {
      const handle = trigger.getAttribute('data-handle');
      const thirdContainer = getThirdContainer(trigger);
      if (!thirdContainer) return;

      hideAllThird();

      thirdContainer.style.display = 'block';

      thirdContainer.querySelectorAll('.third-submenu-content').forEach((group) => {
        group.classList.toggle('active', group.getAttribute('data-parent') === handle);
      });

      thirdContainer.querySelectorAll('.third-submenu-sidebar-link').forEach((l) => {
        l.style.display = l.getAttribute('data-parent') === handle ? 'block' : 'none';
      });

      trigger.classList.add('active');
    }

    triggers.forEach((trigger) => {
      trigger.addEventListener('mouseenter', () => showThirdLevel(trigger));
      trigger.addEventListener('click', () => showThirdLevel(trigger));
    });

    // Скрыть третий уровень при уходе мыши
    thirdSubmenus.forEach((container) => {
      container.addEventListener('mouseleave', () => hideAllThird());
    });

    // При уходе с submenu второго уровня — скрыть, если курсор не над third-submenu
    document.querySelectorAll('.header__submenu').forEach((sub) => {
      sub.addEventListener('mouseleave', () => {
        setTimeout(() => {
          const anyHover = [...thirdSubmenus].some((c) => c.matches(':hover'));
          if (!anyHover) hideAllThird();
        }, 150);
      });
    });

    // Categories panel (2-level, section.settings.third_level_menu)
    const categoriesTrigger = document.querySelector('.categories-level1-trigger');
    const categoriesPanel = document.querySelector('.header__categories-panel');

    if (categoriesTrigger && categoriesPanel) {
      categoriesTrigger.addEventListener('click', () => {
        const isOpen = categoriesPanel.style.display === 'block';
        hideAllThird();
        if (!isOpen) {
          categoriesPanel.style.display = 'block';
          categoriesTrigger.classList.add('active');
        }
      });

      categoriesPanel.addEventListener('mouseleave', () => {
        categoriesPanel.style.display = 'none';
        categoriesTrigger.classList.remove('active');
      });

      // Закрыть при клике вне панели и тригера
      document.addEventListener('click', (e) => {
        if (!categoriesTrigger.contains(e.target) && !categoriesPanel.contains(e.target)) {
          categoriesPanel.style.display = 'none';
          categoriesTrigger.classList.remove('active');
        }
      });
    }
  });
{% endjavascript %}

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
