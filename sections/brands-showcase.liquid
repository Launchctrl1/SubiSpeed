<section class="brand-showcase">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="brand-showcase__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="brand-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'brand' %}
            <div class="brand-item" {{ block.shopify_attributes }}>
              {% if block.settings.brand_link != blank %}
                <a href="{{ block.settings.brand_link }}" class="brand-link">
              {% endif %}
              {% if block.settings.brand_image != blank %}
                {{
                  block.settings.brand_image
                  | image_url: width: 300
                  | image_tag: alt: block.settings.brand_name, class: 'brand-logo', loading: 'lazy'
                }}
              {% else %}
                <div class="brand-placeholder">
                  {% if block.settings.brand_name != blank %}
                    {{ block.settings.brand_name }}
                  {% else %}
                    Brand Logo
                  {% endif %}
                </div>
              {% endif %}
              {% if block.settings.brand_link != blank %}
                </a>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    {% if section.settings.description != blank %}
      <div class="brand-showcase__description">
        {{ section.settings.description }}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .brand-showcase {
    padding: 60px 0 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .brand-showcase__heading {
    font-size: 2.5rem;
    font-weight: 600;
    color: #333;
    margin-bottom: 40px;
    text-align: left;
  }

  .brand-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    margin-bottom: 50px;
  }

  .brand-item {
    aspect-ratio: 163.181 / 72;
    background: white;
    border-radius: 12px;
    padding: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    max-height: 72px;
    width: 100%;
  }

  .brand-item:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .brand-link {
    display: block;
    width: 100%;
    max-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .brand-logo {
    max-width: 207px;
    max-height: 48px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .brand-placeholder {
    color: #666;
    font-weight: 500;
    text-align: center;
  }

  .brand-showcase__description {
    max-width: 900px;
    font-size: 1.1rem;
    line-height: 1.7;
    color: #555;
    text-align: left;
  }

  .brand-showcase__description p {
    margin-bottom: 1.5rem;
  }

  .brand-showcase__description a {
    color: #2563eb;
    text-decoration: underline;
  }

  .brand-showcase__description a:hover {
    color: #1d4ed8;
  }

  /* Tablet Styles */
  @media (max-width: 1024px) {
    .brand-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 25px;
    }

    .brand-showcase__heading {
      font-size: 2.2rem;
    }
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .brand-showcase {
      padding: 40px 0;
    }

    .brand-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .brand-item {
      padding: 12px;
      min-height: 100px;
    }

    .brand-logo {
      max-height: 60px;
    }

    .brand-showcase__heading {
      font-size: 2rem;
      margin-bottom: 30px;
    }

    .brand-showcase__description {
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .brand-grid {
      grid-template-columns: 1fr;
    }

    .brand-showcase__heading {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop our Best Brands"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "Optional description text to display below the brand grid"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "brand_image",
          "label": "Brand Logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "info": "Used for alt text and fallback if no image is provided"
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Showcase",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 1"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 2"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 3"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
