{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-carousel-slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 144 / 45;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    pointer-events: none;
  }

  .ai-carousel-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-carousel-slide-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-carousel-slide-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-carousel-slide-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-carousel-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-carousel-button-wrapper-{{ ai_gen_id }} {
    position: absolute;
    z-index: 2;
    {% assign pos = block.settings.button_position %}
    {% if pos == 'top_left' %}
      top: 6%;
      left: 5%;
      transform: translateY(-20px);
    {% elsif pos == 'top_center' %}
      top: 6%;
      left: 50%;
      transform: translateX(-50%) translateY(-20px);
    {% elsif pos == 'top_right' %}
      top: 6%;
      right: 5%;
      transform: translateY(-20px);
    {% elsif pos == 'center_left' %}
      top: 50%;
      left: 5%;
      transform: translateY(calc(-50% - 20px));
    {% elsif pos == 'center' %}
      top: 50%;
      left: 50%;
      transform: translate(-50%, calc(-50% - 20px));
    {% elsif pos == 'center_right' %}
      top: 50%;
      right: 5%;
      transform: translateY(calc(-50% - 20px));
    {% elsif pos == 'bottom_left' %}
      bottom: 6%;
      left: 5%;
      transform: translateY(-20px);
    {% elsif pos == 'bottom_center' %}
      bottom: 6%;
      left: 50%;
      transform: translateX(-50%) translateY(-20px);
    {% elsif pos == 'bottom_right' %}
      bottom: 6%;
      right: 5%;
      transform: translateY(-20px);
    {% endif %}
  }

  .ai-carousel-button-{{ ai_gen_id }} {
    display: inline-block;
    /* responsive vertical and horizontal padding */
    padding: clamp(6px, 1.2vw, 12px) clamp(12px, 3.2vw, 28px);
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    /* radius and font scale with viewport */
    border-radius: clamp(3px, 0.6vw, 8px);
    font-size: clamp(12px, 1.6vw, 18px);
    line-height: 1;
    transition: background-color 0.3s ease, transform 0.15s ease;
    transform: translateY(-15px);
  }

  @media screen and (min-width: 1439px) {
    .ai-carousel-button-{{ ai_gen_id }} {
      transform: translateY(-45px);
    }
  }

    @media screen and (max-width: 749pxpx) {
    .ai-carousel-button-{{ ai_gen_id }} {
      display:none;
    }
  }

  /* .ai-carousel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  } */

  .ai-carousel-arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_color }};
    color: {{ block.settings.arrow_icon_color }};
    border: none;
    width: 50px;
    height: 50px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_color }};
  }

  .ai-carousel-arrow-{{ ai_gen_id }}.prev {
    left: 20px;
  }

  .ai-carousel-arrow-{{ ai_gen_id }}.next {
    right: 20px;
  }

  .ai-carousel-arrow-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    cursor: pointer;
    border: none;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-carousel-slide-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-carousel-slide-mobile-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slides-{{ ai_gen_id }} {
      aspect-ratio: 4 / 5;
    }

    .ai-carousel-arrow-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-carousel-arrow-{{ ai_gen_id }}.prev {
      left: 10px;
    }

    .ai-carousel-arrow-{{ ai_gen_id }}.next {
      right: 10px;
    }

    /* keep the same percentage-based positions on mobile so the button stays in the same relative place */
    .ai-carousel-button-wrapper-{{ ai_gen_id }} {
      /* no px overrides here; percentages from the main rule will scale */
    }

    .ai-carousel-slide-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-carousel-slide-mobile-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<image-carousel-{{ ai_gen_id }}
  class="ai-carousel-{{ ai_gen_id }}"
  data-autoplay-interval="5000"
  {{ block.shopify_attributes }}
>
  <div class="ai-carousel-slides-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'slide_' | append: i | append: '_image'
        assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
        assign button_text_key = 'slide_' | append: i | append: '_button_text'
        assign button_link_key = 'slide_' | append: i | append: '_button_link'
        assign show_button_key = 'slide_' | append: i | append: '_show_button'

        assign slide_image = block.settings[image_key]
        assign mobile_image = block.settings[mobile_image_key]
        assign button_text = block.settings[button_text_key]
        assign button_link = block.settings[button_link_key]
        assign show_button = block.settings[show_button_key]
      %}

      {% if slide_image or mobile_image %}
        <div
          class="ai-carousel-slide-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}"
          data-slide-index="{{ forloop.index0 }}"
        >
          {% if slide_image %}
            <img
              src="{{ slide_image | image_url: width: 2000 }}"
              alt="{{ slide_image.alt | escape }}"
              loading="lazy"
              width="{{ slide_image.width }}"
              height="{{ slide_image.height }}"
              class="ai-carousel-slide-image-{{ ai_gen_id }} ai-carousel-slide-desktop-{{ ai_gen_id }}"
            >
          {% endif %}
          {% if mobile_image %}
            <img
              src="{{ mobile_image | image_url: width: 1000 }}"
              alt="{{ mobile_image.alt | escape }}"
              loading="lazy"
              width="{{ mobile_image.width }}"
              height="{{ mobile_image.height }}"
              class="ai-carousel-slide-image-{{ ai_gen_id }} ai-carousel-slide-mobile-{{ ai_gen_id }}"
            >
          {% endif %}
          {% if show_button and button_text != blank %}
            <div class="ai-carousel-button-wrapper-{{ ai_gen_id }}">
              <a href="{{ button_link }}" class="ai-carousel-button-{{ ai_gen_id }}">
                {{ button_text }}
              </a>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

    {% assign has_images = false %}
    {% for i in (1..5) %}
      {% liquid
        assign image_key = 'slide_' | append: i | append: '_image'
        assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
        assign slide_image = block.settings[image_key]
        assign mobile_image = block.settings[mobile_image_key]
      %}
      {% if slide_image or mobile_image %}
        {% assign has_images = true %}
        {% break %}
      {% endif %}
    {% endfor %}

    {% unless has_images %}
      <div class="ai-carousel-slide-{{ ai_gen_id }} active" data-slide-index="0">
        <div class="ai-carousel-slide-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-carousel-empty-state-{{ ai_gen_id }}">Next, add images to your slides</div>
        </div>
      </div>
    {% endunless %}
  </div>

  {% if has_images %}
    {% if block.settings.show_arrows %}
      <button class="ai-carousel-arrow-{{ ai_gen_id }} prev" aria-label="Previous slide">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button class="ai-carousel-arrow-{{ ai_gen_id }} next" aria-label="Next slide">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-carousel-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  {% endif %}
</image-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.slides = [];
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-carousel-slide-{{ ai_gen_id }}'));
        
        if (this.slides.length === 0) return;

        this.prevButton = this.querySelector('.ai-carousel-arrow-{{ ai_gen_id }}.prev');
        this.nextButton = this.querySelector('.ai-carousel-arrow-{{ ai_gen_id }}.next');
        this.dotsContainer = this.querySelector('.ai-carousel-dots-{{ ai_gen_id }}');

        this.createDots();
        this.setupEventListeners();
        this.startAutoplay();
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }

      createDots() {
        if (!this.dotsContainer) return;

        this.slides.forEach((slide, index) => {
          const dot = document.createElement('button');
          dot.classList.add('ai-carousel-dot-{{ ai_gen_id }}');
          if (index === 0) dot.classList.add('active');
          dot.setAttribute('aria-label', `Go to slide ${index + 1}`);
          dot.addEventListener('click', () => this.goToSlide(index));
          this.dotsContainer.appendChild(dot);
        });
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => this.startAutoplay());
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        
        const dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
        if (dots[this.currentSlide]) {
          dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (dots[this.currentSlide]) {
          dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        const interval = parseInt(this.dataset.autoplayInterval) || 5000;
        this.autoplayInterval = setInterval(() => this.nextSlide(), interval);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }
    }

    customElements.define('image-carousel-{{ ai_gen_id }}', ImageCarousel{{ ai_gen_id }});
  })();
</script>

